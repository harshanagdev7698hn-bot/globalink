generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  BUYER
  CONSULTANT
  LAB
  SELLER
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  password       String
  role           Role
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  consultant     ConsultantProfile?
  buyer          BuyerProfile?
  seller         SellerProfile?
  lab            LabProfile?

  products       Product[]
  rfqs           RFQ[]
  reviews        Review[]
  kycDocs        KycDocument[]
  certifications Certification[]
}

model ConsultantProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  company            String?
  expertise          String
  country            String
  city               String?
  services           String
  experienceYears    Int      @default(0)
  pricing            String?
  phone              String?
  whatsapp           String?
  website            String?
  bio                String?
  verified           Boolean  @default(false)
  averageRating      Float    @default(0)
  totalReviews       Int      @default(0)
  totalProjects      Int      @default(0)
  responseTime       String?

  gstNumber          String?
  msmeNumber         String?
  gstFile            String?
  msmeFile           String?
  verificationStatus String   @default("PENDING")
  isVerified         Boolean  @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id])
}

model BuyerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String?
  country     String
  user        User     @relation(fields: [userId], references: [id])
}

model SellerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String?
  country     String
  verified    Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])
}

model LabProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  labName        String
  accreditation  String?
  country        String
  verified       Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id])
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
}

model RFQ {
  id          String   @id @default(cuid())
  title       String
  description String
  budget      Float?
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  createdAt   DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  consultantId String
  userId       String
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model KycDocument {
  id          String    @id @default(cuid())
  title       String
  fileUrl     String
  status      KycStatus @default(PENDING)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model Certification {
  id                  String              @id @default(cuid())
  name                String
  authority           String
  category            String
  country             String
  documentUrl         String?
  status              CertificationStatus @default(PENDING)
  validTill           DateTime?
  userId              String
  user                User                @relation(fields: [userId], references: [id])

  licenseNumber       String?
  certificationBody   String?
  scope               String?
  isNumber            String?
  productType         String?
  factoryLocation     String?
  foodCategory        String?
  state               String?
  approvalType        String?
  productClass        String?

  adminRemark         String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model CertificateMaster {
  id        String   @id @default(cuid())
  name      String
  authority String
  country   String
  category  String
  type      String
  createdAt DateTime @default(now())
}