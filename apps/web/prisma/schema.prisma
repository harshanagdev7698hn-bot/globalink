generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  CONSULTANT
  LAB
  SELLER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  country   String?
  city      String?
  phone     String?
  whatsapp  String?
  company   String?

  gstNumber String?
  gstFile   String?

  status VerificationStatus @default(PENDING)

  consultantProfile ConsultantProfile?
  labProfile        LabProfile?
  sellerProfile     SellerProfile?
  certifications    Certification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsultantProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  services   String?
  experience String?
  pricing    String?
  msmeNumber String?
  msmeFile   String?
  shortBio   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LabProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  nablFile          String?
  bisApprovalFile   String?
  labScope          String?
  testingCategories String?
  contactPerson     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  bisLicenceNo    String?
  bisLicenceFile  String?
  productCategory String?
  brandName       String?
  factoryAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certification {
  id                String    @id @default(cuid())
  name              String
  authority         String
  category          String
  country           String
  documentUrl       String?
  validTill         DateTime?
  licenseNumber     String?
  certificationBody String?
  scope             String?
  isNumber          String?
  productType       String?
  factoryLocation   String?
  foodCategory      String?
  state             String?
  approvalType      String?
  productClass      String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Inquiry {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  company     String?
  requirement String
  source      String   @default("CONTACT_PAGE")
  status      String   @default("NEW")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}